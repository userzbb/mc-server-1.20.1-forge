{
  "nickname": "Forge 1.20.1",
  "processType": "docker",
  "type": "minecraft",
  "cwd": "/data",
  "docker": {
    "image": "itzg/minecraft-server:java17",
    "containerName": "mc-forge",
    "startCommand": "",
    "stopCommand": "^c",
    "ports": [
      {
        "host": "25565",
        "container": "25565",
        "type": "tcp"
      },
      {
        "host": "25575",
        "container": "25575",
        "type": "tcp"
      },
      {
        "host": "24454",
        "container": "24454",
        "type": "udp"
      }
    ],
    "extraVolumes": [
      {
        "host": "/home/yuan/minecraft-server/mods",
        "container": "/mods",
        "mode": "ro"
      }
    ],
    "env": [
      {
        "key": "EULA",
        "value": "TRUE"
      },
      {
        "key": "TYPE",
        "value": "FORGE"
      },
      {
        "key": "VERSION",
        "value": "1.20.1"
      },
      {
        "key": "FORGE_VERSION",
        "value": "47.4.21"
      },
      {
        "key": "ONLINE_MODE",
        "value": "false"
      },
      {
        "key": "MEMORY",
        "value": "4G"
      },
      {
        "key": "MAX_PLAYERS",
        "value": "20"
      },
      {
        "key": "TZ",
        "value": "Asia/Shanghai"
      }
    ],
    "workingDir": "/data",
    "changeWorkdir": true,
    "memory": 0,
    "networkMode": "bridge"
  }
}