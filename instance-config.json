{
  "nickname": "Forge 1.20.1",
  "processType": "docker",
  "type": "minecraft",
  "cwd": null,
  "docker": {
    "image": "itzg/minecraft-server:java17",
    "containerName": "mc-forge",
    "startCommand": "",
    "stopCommand": "^c",
    "ports": [
      "25565:25565/tcp",
      "25575:25575/tcp",
      "24454:24454/udp"
    ],
    "extraVolumes": [
      "/home/yuan/minecraft-server/mods|/mods|ro"
    ],
    "env": [
      "EULA=TRUE",
      "TYPE=FORGE",
      "VERSION=1.20.1",
      "FORGE_VERSION=47.4.21",
      "ONLINE_MODE=false",
      "MEMORY=4G",
      "MAX_PLAYERS=20",
      "TZ=Asia/Shanghai"
    ],
    "workingDir": "/data",
    "memory": 0,
    "networkMode": "bridge"
  }
}
